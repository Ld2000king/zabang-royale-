{
  // ==========================================================================
  // Firebase Realtime Database Security Rules - Zabang Royale
  //
  // Deploy: Firebase Console -> Realtime Database -> Rules -> paste -> Publish
  //   (or `firebase deploy --only database` with firebase.json pointing here).
  //
  // BEFORE DEPLOYING:
  //   Replace every  PASTE_ADMIN_UID_HERE  with the real UID of the admin
  //   Auth account (the email/password account used by adminSignIn() in
  //   admin.js). Find it in Console -> Authentication -> Users -> User UID.
  //
  // IDENTITY BINDING (now active):
  //   Each room player node carries "uid" = the writer's Firebase Auth UID
  //   (set by myPlayerNode() in multiplayer.js). These rules use it so that:
  //     * a player may only create/delete/edit the node whose uid is their own;
  //     * only the room HOST may reset other players' scores, mark a player
  //       eliminated, clear foundWords, or set status/winnerId/loserId/board;
  //     * freezeUntil is the one cross-player field (the freeze power-up), and
  //       it is capped to <= now + 15s so no one can freeze an opponent forever.
  //
  // REMAINING TRUST NOTES (inherent to host-authoritative P2P, not fixable
  // with Rules alone):
  //   * A player can still inflate their OWN score - Rules can't tell a real
  //     word from a fake one. True score integrity needs a Cloud Function that
  //     is the sole score writer.
  //   * The HOST is a trusted role: it computes round results and the winner,
  //     so a cheating host could rig its own match. Only server authority
  //     (Cloud Functions) removes that trust.
  //   * /leaderboard keys are the game's own playerId (a push key), not the
  //     auth UID, so leaderboard entries are validated for shape but not
  //     identity-bound. Bind by switching writes to leaderboard/{auth.uid}.
  // ==========================================================================

  "rules": {
    // deny everything by default; each subtree below re-opens only what it needs
    ".read": false,
    ".write": false,

    "rooms": {
      "$code": {
        ".read": "auth != null",

        // $code-level writes are only: initial creation (room doesn't exist
        // yet) or deletion by the host (cleanup / onDisconnect). All in-match
        // mutations happen on deeper leaves, governed by the field rules below,
        // so the host never needs blanket write over the whole room object.
        ".write": "auth != null && (!data.exists() || (root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid && !newData.exists()))",

        // ---- room-scalar fields ----
        // Host-only after creation (creation is granted by the $code rule's
        // cascade, so these still populate on the initial .set()).
        "status":         { ".validate": "newData.isString() && newData.val().matches(/^(waiting|playing|roundEnd|finished)$/)", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
        "board":          { ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid", "$i": { ".validate": "newData.isString() && newData.val().length <= 4" } },
        "currentRound":   { ".validate": "newData.isNumber() && newData.val() >= 0", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
        "roundStartTime": { ".validate": "newData.isNumber()", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
        "winnerId":       { ".validate": "newData.isString()", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
        "loserId":        { ".validate": "newData.isString()", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
        "isDraw":         { ".validate": "newData.isBoolean()", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },

        // set once at creation only (no post-create writer)
        "hostId":           { ".validate": "newData.isString()" },
        "matchType":        { ".validate": "newData.isString() && newData.val().matches(/^(friends|random)$/)" },
        "boardTheme":       { ".validate": "newData.isNumber()" },
        "totalRounds":      { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "roundDurationSec": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "createdAt":        { ".validate": "newData.isNumber()" },

        "players": {
          "$pid": {
            // Own node: create/edit/delete the node whose uid is mine. Field
            // rules below GRANT extra writers (host, freeze) on top of this.
            ".write": "auth != null && (newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)",

            // uid can never be set to anyone other than the writer
            "uid":         { ".validate": "newData.isString() && newData.val() === auth.uid" },
            "name":        { ".validate": "newData.isString() && newData.val().length <= 40" },
            "avatarId":    { ".validate": "newData.isString() || newData.isNumber()" },
            "eliminated":  { ".validate": "newData.isBoolean()", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },
            "connected":   { ".validate": "newData.isBoolean()" },

            // owner (via parent) writes it; host also writes it to reset to 0
            // each round - so grant host here too
            "score":       { ".validate": "newData.isNumber() && newData.val() >= 0", ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid" },

            // cross-player: any authed player may freeze this player, but only
            // for a bounded window (<= 15s ahead of server time), and host
            // clears it to 0 on round reset
            "freezeUntil": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= now + 15000", ".write": "auth != null" },

            // owner (via parent) adds words; host clears the whole map to null
            // on round reset
            "foundWords": {
              ".write": "root.child('rooms').child($code).child('players').child(root.child('rooms').child($code).child('hostId').val()).child('uid').val() === auth.uid",
              "$word": { ".validate": "newData.isBoolean()" }
            },

            // no unexpected fields on a player node
            "$other": { ".validate": false }
          }
        },

        // reject any room-level field the game doesn't use
        "$other": { ".validate": false }
      }
    },

    "matchmaking_queue": {
      // findWaitingOpponent() lists the whole queue, so read is collection-wide.
      // Writes stay open to any authed player because tryJoinOpponent() runs a
      // transaction that nulls an OPPONENT's ticket to claim them.
      ".read": "auth != null",
      "$pid": {
        ".write": "auth != null",
        "roomCode":  { ".validate": "newData.isString() && newData.val().length <= 8" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "leaderboard": {
      ".read": "auth != null",
      "$pid": {
        ".write": "auth != null",
        "name":      { ".validate": "newData.isString() && newData.val().length <= 40" },
        "score":     { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "avatarId":  { ".validate": "newData.isString() || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "pending_requests": {
      // only the admin may LIST/READ the queue or delete from it
      ".read": "auth != null && auth.uid === 'PASTE_ADMIN_UID_HERE'",
      "$req": {
        // players may CREATE a new request (no overwrite of an existing one);
        // the admin may modify/remove any request
        ".write": "auth != null && (auth.uid === 'PASTE_ADMIN_UID_HERE' || (!data.exists() && newData.exists()))",
        "word":        { ".validate": "newData.isString() && newData.val().length <= 20" },
        "points":      { ".validate": "newData.isNumber()" },
        "submittedBy": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "timestamp":   { ".validate": "newData.isNumber()" },
        "$other":      { ".validate": false }
      }
    },

    "approved_words": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'PASTE_ADMIN_UID_HERE'",
      "$word": { ".validate": "newData.isNumber() && newData.val() >= 0" }
    },

    "rejected_words": {
      ".read": "auth != null",
      ".write": "auth != null && auth.uid === 'PASTE_ADMIN_UID_HERE'",
      "$word": { ".validate": "newData.isBoolean()" }
    }
  }
}
